{
  "manifest_version": 3,
  "name": "Codeforces Daily Momentum",
  "version": "1.0.0",
  "description": "Track Codeforces problem-solving momentum over the last 30 days directly on the profile.",
  "permissions": [],
  "host_permissions": [
    "https://codeforces.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://codeforces.com/profile/*"],
      "css": ["content.css"],
      "js": ["chart.umd.js", "content.js"],
      "run_at": "document_end"
    }
  ]
}
